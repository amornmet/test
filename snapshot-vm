#!/bin/bash
 
# --- การตั้งค่า ---
POOL_NAME="data-site-a01" # เปลี่ยนชื่อ Pool ให้ตรงกับของคุณ
RETENTION_DAYS=7
LOG_RETENTION_DAYS=30
LOG_DIR="/var/log/rbd_snapshots"
DATE=$(date +%Y-%m-%d)
CURRENT_LOG="$LOG_DIR/snapshot_$DATE.log"
PERF_LOG="$LOG_DIR/ceph_perf_$DATE.log"
VM_LIST=(2001 2002 2003 2004 5001 5002 5003) # ใส่ VMID ที่ต้องการทำ Snapshot
 
mkdir -p $LOG_DIR
 
# --- ฟังก์ชันบันทึก Performance ---
record_ceph_perf() {
    echo "=== Ceph Performance Report: $DATE $(date +%H:%M:%S) ===" >> $PERF_LOG
    /usr/bin/ceph -s >> $PERF_LOG
    echo -e "\n--- Pool Usage ---" >> $PERF_LOG
    /usr/bin/ceph df >> $PERF_LOG
    echo -e "\n--- OSD Latency ---" >> $PERF_LOG
    /usr/bin/ceph osd perf >> $PERF_LOG
}
 
# --- ฟังก์ชันเช็คโหลด ---
wait_for_low_io() {
    while true; do
        IOWAIT=$(/usr/bin/top -bn1 | grep "Cpu(s)" | awk '{print $10}' | cut -d'.' -f1)
        if [ "$IOWAIT" -lt 15 ]; then break; fi
        sleep 5
    done
}
 
# บันทึกสถานะก่อนเริ่ม
record_ceph_perf
 
echo "=== Start Snapshot Task: $DATE ===" > $CURRENT_LOG
 
# --- เริ่ม Loop ทำ Snapshot ---
SUCCESS_COUNT=0
FAIL_COUNT=0
 
for VMID in "${VM_LIST[@]}"; do
    # ดึงชื่อ VM
    VM_NAME=$(/usr/sbin/qm config $VMID | grep ^name | cut -d' ' -f2)
    
    # ค้นหาดิสก์ทั้งหมดของ VMID นั้นๆ ใน Pool
    DISK_LIST=$(/usr/bin/rbd ls $POOL_NAME | grep "vm-${VMID}-disk-")
 
    for IMAGE_NAME in $DISK_LIST; do
        wait_for_low_io
        
        # --- ปรับปรุงตรงนี้: ดึงชื่อ Disk (เช่น disk-0) มาใส่ในชื่อ Snapshot ---
        DISK_ID=$(echo $IMAGE_NAME | awk -F'-' '{print $(NF-1)"-"$NF}')
        SNAP_NAME="SNAPSHOT_${DATE}_${VM_NAME}_${VMID}_${DISK_ID}"
 
        echo "[$(date +%H:%M:%S)] Processing Disk: $IMAGE_NAME for VM: $VMID..." >> $CURRENT_LOG
 
        # 1. สร้าง Snapshot
        if /usr/bin/rbd snap create $POOL_NAME/$IMAGE_NAME@$SNAP_NAME 2>>$CURRENT_LOG; then
            echo "  - [SUCCESS] Created: $SNAP_NAME" >> $CURRENT_LOG
            ((SUCCESS_COUNT++))
        else
            echo "  - [FAILED] Could not create snapshot for $IMAGE_NAME" >> $CURRENT_LOG
            ((FAIL_COUNT++))
            continue
        fi
 
        # 2. จัดการ Retention
        SNAPS=$(/usr/bin/rbd snap ls $POOL_NAME/$IMAGE_NAME --format json | /usr/bin/jq -r '.[].name')
        for SNAP in $SNAPS; do
            # ตรวจสอบสถานะ Protect
            if /usr/bin/rbd snap protect $POOL_NAME/$IMAGE_NAME@$SNAP 2>/dev/null; then
                /usr/bin/rbd snap unprotect $POOL_NAME/$IMAGE_NAME@$SNAP
                SNAP_DATE=$(echo $SNAP | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')
                if [[ -n "$SNAP_DATE" ]]; then
                    DIFF=$(( ($(date +%s) - $(date -d "$SNAP_DATE" +%s)) / 86400 ))
                    if [ $DIFF -gt $RETENTION_DAYS ]; then
                        /usr/bin/rbd snap rm $POOL_NAME/$IMAGE_NAME@$SNAP
                        echo "  - [CLEANUP] Deleted old snapshot: $SNAP" >> $CURRENT_LOG
                    fi
                fi
            fi
        done
    done
done
 
# --- สรุปผล ---
echo -e "\n=== Summary ===" >> $CURRENT_LOG
echo "Success: $SUCCESS_COUNT" >> $CURRENT_LOG
echo "Failed: $FAIL_COUNT" >> $CURRENT_LOG
echo "Task finished at $(date)" >> $CURRENT_LOG
 
# --- จัดการไฟล์ Log และบีบอัดด้วย Tar ---
cd $LOG_DIR
/bin/tar -czf "snapshot_report_$DATE.tar.gz" "snapshot_$DATE.log" "ceph_perf_$DATE.log"
rm "snapshot_$DATE.log" "ceph_perf_$DATE.log"
 
# ลบไฟล์เก่าที่เกิน LOG_RETENTION_DAYS
/usr/bin/find $LOG_DIR -name "snapshot_report_*.tar.gz" -mtime +$LOG_RETENTION_DAYS -exec rm {} \;